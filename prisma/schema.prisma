generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Report {
  id            Int      @id @default(autoincrement())
  createdAt      DateTime @default(now())
  resumeText    String   @db.Text
  jobDescription String  @db.Text
  matchScore    Int
  missingSkills String[] 
  actionPlan    String[]
}
